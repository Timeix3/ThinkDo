# PostgreSQL
POSTGRES_DB=tododb
POSTGRES_USER=todouser
POSTGRES_PASSWORD=todopassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Connection string
CONNECTION_STRING=Host=postgres;Port=5432;Database=tododb;Username=todouser;Password=todopassword

# GitHub OAuth2 credentials — не указывать здесь.
